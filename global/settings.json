{
  "permissions": {
    "allow": [
      "Bash(claude:*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(copy:*)",
      "Bash(mv:*)",
      "Bash(move:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(cd:*)",
      "Bash(vitest:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(gh:*)",
      "Bash(python3:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Skill",
      "LSP"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(format:*)",
      "Bash(del /s /q C:*)",
      "Bash(reg:*)",
      "Bash(shutdown:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "coderabbit@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "semgrep@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-protected-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-commit-review.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-lint-python.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-lint-typescript.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ripple-check.sh"
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "max"
}
