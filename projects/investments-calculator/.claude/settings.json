{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-review.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-css-variables.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-lint-typescript.sh"
          }
        ]
      }
    ]
  }
}
